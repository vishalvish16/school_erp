## Screen State Boilerplate (list screens)

Every list screen uses this exact state pattern:

```dart
class _ScreenState extends ConsumerState<Screen> {
  bool _loading = true;
  bool _loadingMore = false;  // mobile infinite scroll only
  String? _error;
  List<Model> _items = [];
  int _page = 1;
  int _totalPages = 1;
  int _total = 0;
  int _pageSize = 15;
  static const _pageSizeOptions = [10, 15, 25, 50];
  final _searchController = TextEditingController();
  Timer? _debounceTimer;
  // filter state fields ...

  @override
  void initState() {
    super.initState();
    _searchController.addListener(_onSearchChanged);
    WidgetsBinding.instance.addPostFrameCallback((_) { if (mounted) _load(); });
  }

  void _onSearchChanged() {
    if (mounted) setState(() {});
    _debounceTimer?.cancel();
    _debounceTimer = Timer(Duration(milliseconds: 400), () {
      if (mounted) { setState(() => _page = 1); _load(); }
    });
  }

  @override
  void dispose() {
    _debounceTimer?.cancel();
    _searchController.removeListener(_onSearchChanged);
    _searchController.dispose();
    super.dispose();
  }

  Future<void> _load({bool append = false}) async {
    if (!mounted) return;
    if (append) {
      if (_loadingMore || _loading) return;
      if (_items.isNotEmpty && _items.length >= _total && _total > 0) return;
      setState(() => _loadingMore = true);
    } else {
      setState(() { _loading = true; _error = null; });
    }
    try {
      final result = await ref.read(serviceProvider).getItems(page: ..., limit: _pageSize, search: ...);
      if (mounted) setState(() {
        if (append) {
          _items = [..._items, ...result.data];
          _loadingMore = false;
        } else {
          _items = result.data;
          _loading = false;
        }
        _total = result.total;
        _totalPages = result.totalPages;
      });
    } catch (e) {
      if (mounted) setState(() {
        if (append) { _loadingMore = false; }
        else { _error = e.toString().replaceAll('Exception: ', ''); _loading = false; _items = []; }
      });
    }
  }

  bool get _hasMore => _items.isNotEmpty && _total > 0 && _items.length < _total;
}
```

### Screen build() — state routing

```dart
@override
Widget build(BuildContext context) {
  final isWide  = MediaQuery.sizeOf(context).width >= AppBreakpoints.tablet; // 768
  final isNarrow = MediaQuery.sizeOf(context).width < 600;
  return RefreshIndicator(
    onRefresh: () async { setState(() => _page = 1); await _load(); },
    child: LayoutBuilder(builder: (context, constraints) {
      return Column(crossAxisAlignment: CrossAxisAlignment.stretch, children: [
        // Header
        if (isNarrow)
          ListScreenMobileHeader(title: '...', primaryLabel: AppStrings.addX, onPrimary: _openAdd,
            onExport: _export, exportEnabled: !_loading)
        else
          Padding(padding: EdgeInsets.fromLTRB(24, 24, 24, 16), child: Wrap(
            spacing: 12, runSpacing: 12,
            alignment: WrapAlignment.spaceBetween,
            crossAxisAlignment: WrapCrossAlignment.center,
            children: [
              Text(AppStrings.xTitle, style: Theme.of(context).textTheme.headlineSmall?.copyWith(fontWeight: FontWeight.bold)),
              Row(mainAxisSize: MainAxisSize.min, children: [
                TextButton.icon(onPressed: _loading ? null : _export, icon: Icon(Icons.download, size: 18), label: Text(AppStrings.export)),
                AppSpacing.hGapSm,
                FilledButton.icon(onPressed: _openAdd, icon: Icon(Icons.add, size: 20), label: Text(AppStrings.addX)),
              ]),
            ],
          )),
        // Filters
        if (isNarrow) _buildMobileSearchFilters(context)
        else _buildWideSearchFilters(context),
        if (isNarrow) SizedBox(height: 8) else AppSpacing.vGapLg,
        // Content
        Expanded(child: isNarrow
          ? Padding(padding: EdgeInsets.fromLTRB(16, 0, 16, 16), child: _buildContent(isWide))
          : Center(child: Padding(padding: EdgeInsets.fromLTRB(24, 0, 24, 24), child: _buildContent(isWide)))),
      ]);
    }),
  );
}
```

### _buildContent — loading / error / empty / list routing

```dart
Widget _buildContent(bool isWide) {
  // Loading
  if (_loading && _items.isEmpty) return Center(child: CircularProgressIndicator());
  // Error
  if (_error != null && _items.isEmpty) return Card(child: Padding(
    padding: AppSpacing.paddingXl,
    child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
      Icon(Icons.error_outline, size: 48, color: Theme.of(context).colorScheme.error),
      AppSpacing.vGapLg,
      Text(_error!, textAlign: TextAlign.center),
      AppSpacing.vGapLg,
      FilledButton(onPressed: _load, child: Text(AppStrings.retry)),
    ]),
  ));
  // Empty
  if (_items.isEmpty) return Center(child: Padding(
    padding: EdgeInsets.all(48),
    child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
      Icon(Icons.entity_outlined, size: 64, color: Theme.of(context).colorScheme.outline),
      AppSpacing.vGapLg,
      Text(_searchController.text.isNotEmpty
        ? "No results for '${_searchController.text}'"
        : AppStrings.noXFound,
        style: Theme.of(context).textTheme.titleMedium, textAlign: TextAlign.center),
      AppSpacing.vGapSm,
      TextButton(onPressed: _clearFilters, child: Text(AppStrings.clearFilters)),
    ]),
  ));
  return _buildList(isWide);
}
```

### _buildList — table vs mobile cards

```dart
Widget _buildList(bool isWide) {
  if (isWide) {
    return Center(child: ConstrainedBox(
      constraints: BoxConstraints(maxWidth: _tableContentWidth),
      child: Card(child: Column(crossAxisAlignment: CrossAxisAlignment.stretch, children: [
        Expanded(child: ListTableView(
          columns: const ['Col1', 'Col2', ...],
          columnWidths: _columnWidths,
          showSrNo: false,
          itemCount: _items.length,
          rowBuilder: (i) => _buildDataRow(_items[i]),
        )),
        _buildPaginationRow(),           // ListPaginationBar inside same Card
      ])),
    ));
  }
  return MobileInfiniteScrollList(
    itemCount: _items.length,
    itemBuilder: (context, i) => _buildMobileCard(_items[i]),
    hasMore: _hasMore,
    isLoadingMore: _loadingMore,
    onLoadMore: () => _load(append: true),
    loadingLabel: 'Loading more…',
  );
}

Widget _buildPaginationRow() => ListPaginationBar(
  currentPage: _page,
  totalPages: _totalPages,
  totalEntries: _total,
  pageSize: _pageSize,
  pageSizeOptions: _pageSizeOptions,
  onPageSizeChanged: (v) { if (v != null) { setState(() { _pageSize = v; _page = 1; }); _load(); } },
  onGoToPage: (p) { if (p < 1 || p > _totalPages) return; setState(() => _page = p); _load(); },
);
```


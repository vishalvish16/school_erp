## Mobile Card Pattern — complete code (_buildMobileCard)

```dart
Widget _buildMobileCard(EntityModel s) {
  final cs = Theme.of(context).colorScheme;
  final smallMuted = Theme.of(context).textTheme.bodySmall?.copyWith(color: cs.onSurfaceVariant);
  return Card(
    margin: EdgeInsets.only(bottom: 8),
    child: InkWell(
      onTap: () => _openDetail(s),          // card tap = primary action (detail)
      borderRadius: AppRadius.brLg,
      child: Padding(
        padding: AppSpacing.paddingLg,
        child: Column(crossAxisAlignment: CrossAxisAlignment.stretch, children: [
          // ── Row 1: Name + ⋮ menu ──────────────────────────────────
          Row(crossAxisAlignment: CrossAxisAlignment.start, children: [
            Expanded(child: Text(s.name,
              style: TextStyle(fontWeight: FontWeight.w600, fontSize: 16))),
            HoverPopupMenu<String>(
              icon: Icon(Icons.more_vert, size: 22),
              padding: EdgeInsets.zero,
              onSelected: (v) => _onMenuSelected(s, v),
              itemBuilder: (ctx) => _menuItems(s, omitManage: true),
              // omitManage: true on mobile — card tap already opens detail
            ),
          ]),
          SizedBox(height: 4),
          // ── Subtitle: secondary metadata ──────────────────────────
          Text('${s.field1} · ${s.field2}', style: smallMuted),
          // ── Divider ───────────────────────────────────────────────
          Padding(
            padding: EdgeInsets.symmetric(vertical: 10),
            child: Divider(height: 1, thickness: 1,
              color: cs.outlineVariant.withValues(alpha: 0.5)),
          ),
          // ── Row 2: Left column + Right column (chips + date) ──────
          Row(crossAxisAlignment: CrossAxisAlignment.start, children: [
            Expanded(child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
              // Location row (optional — only when location exists)
              if (s.city != null && s.city!.trim().isNotEmpty) ...[
                Row(children: [
                  Icon(Icons.location_on_outlined, size: 16, color: cs.onSurfaceVariant),
                  SizedBox(width: 4),
                  Expanded(child: Text(s.city!, style: smallMuted,
                    maxLines: 1, overflow: TextOverflow.ellipsis)),
                ]),
                SizedBox(height: 6),
              ],
              // ID / code line
              Text('ID: ${s.code}', style: smallMuted, maxLines: 1, overflow: TextOverflow.ellipsis),
              SizedBox(height: 6),
              // Stats / key metrics line
              Text('Students: ${s.studentCount} · Staff: ${s.staffCount}',
                style: smallMuted, maxLines: 1, overflow: TextOverflow.ellipsis),
            ])),
            SizedBox(width: 8),
            // Right: chips + date
            Column(crossAxisAlignment: CrossAxisAlignment.end, mainAxisSize: MainAxisSize.min, children: [
              Wrap(alignment: WrapAlignment.end, spacing: 6, runSpacing: 6, children: [
                // Plan chip
                Chip(
                  label: Text(s.plan?.name ?? '—', style: Theme.of(context).textTheme.labelMedium),
                  visualDensity: VisualDensity.compact,
                  materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                  padding: EdgeInsets.symmetric(horizontal: 8),
                  side: BorderSide(color: cs.outlineVariant),
                  backgroundColor: cs.surfaceContainerHighest.withValues(alpha: 0.5),
                ),
                // Status chip (semantic color)
                Chip(
                  label: Text(statusLabel),
                  visualDensity: VisualDensity.compact,
                  materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                  padding: EdgeInsets.symmetric(horizontal: 8),
                  backgroundColor: _statusColor(s.status),
                ),
              ]),
              SizedBox(height: 8),
              // Date line (right-aligned)
              Text('Expiry: ${_formatDate(s.expiryDate)}',
                style: smallMuted, textAlign: TextAlign.end),
            ]),
          ]),
        ]),
      ),
    ),
  );
}

// Status chip semantic colors — use AppColors tokens, never hardcode hex
Color? _statusColor(String? status) {
  switch (status?.toLowerCase()) {
    case 'active':    return AppColors.success500.withValues(alpha: 0.20);
    case 'trial':     return AppColors.secondary500.withValues(alpha: 0.20);
    case 'suspended': return AppColors.error500.withValues(alpha: 0.20);
    case 'expiring':  return AppColors.warning500.withValues(alpha: 0.20);
    default:          return null;
  }
}
```

### PopupMenu items — desktop vs mobile difference

```dart
// Desktop table row: include Manage (opens detail dialog)
HoverPopupMenu(itemBuilder: (ctx) => _menuItems(s, omitManage: false))

// Mobile card ⋮ menu: omit Manage — card tap already opens detail
HoverPopupMenu(itemBuilder: (ctx) => _menuItems(s, omitManage: true))

List<PopupMenuEntry<String>> _menuItems(Entity s, {required bool omitManage}) {
  final items = <PopupMenuEntry<String>>[];
  if (!omitManage) items.add(PopupMenuItem(value: 'manage',
    child: ListTile(leading: Icon(Icons.settings, size: 20), title: Text(AppStrings.manage), dense: true)));
  items.add(PopupMenuItem(value: 'edit',
    child: ListTile(leading: Icon(Icons.edit, size: 20), title: Text(AppStrings.edit), dense: true)));
  // conditional items based on entity state:
  if (s.status == 'suspended') items.add(PopupMenuItem(value: 'activate', ...));
  return items;
}

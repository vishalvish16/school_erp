{
    "name": "school-erp-backend",
    "version": "1.0.0",
    "description": "Multi-tenant School ERP Platform Backend",
    "main": "src/server.js",
    "type": "module",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "postinstall": "prisma generate",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "pm2:start": "pm2 start ecosystem.config.cjs --watch",
        "pm2:stop": "pm2 stop school-erp-backend",
        "pm2:restart": "pm2 restart school-erp-backend",
        "pm2:delete": "pm2 delete school-erp-backend",
        "pm2:logs": "pm2 logs",
        "pm2:update-daemon": "pm2 update",
        "pm2:status": "pm2 status",
        "seed:staff": "node prisma/seed-staff-credentials.js"
    },
    "dependencies": {
        "@prisma/client": "^6.9.0",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "express-rate-limit": "^7.4.1",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.1",
        "otplib": "^13.3.0",
        "pm2": "^6.0.14",
        "firebase-admin": "^13.0.1",
        "socket.io": "^4.7.5",
        "winston": "^3.12.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "nodemon": "^3.1.0",
        "prisma": "^6.9.0"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    }
}

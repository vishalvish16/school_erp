}

model RouteStop {
  id               String   @id @default(uuid()) @db.Uuid
  routeId          String   @map("route_id") @db.Uuid
  sequence         Int      @db.SmallInt
  name             String   @db.VarChar(100)
  address          String?  @db.Text
  lat              Decimal? @db.Decimal(10, 7)
  lng              Decimal? @db.Decimal(10, 7)
  estimatedArrival String?  @map("estimated_arrival") @db.VarChar(8)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  route TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, sequence])
  @@index([routeId])
  @@map("route_stops")
}

model DriverTrip {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  driverId  String    @map("driver_id") @db.Uuid
  vehicleId String?   @map("vehicle_id") @db.Uuid
  routeId   String?   @map("route_id") @db.Uuid
  status    String    @default("NOT_STARTED") @db.VarChar(20)
  startedAt DateTime? @map("started_at") @db.Timestamptz(6)
  endedAt   DateTime? @map("ended_at") @db.Timestamptz(6)
  notes     String?   @db.Text
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  driver        Driver             @relation("DriverTrips", fields: [driverId], references: [id], onDelete: Cascade)
  vehicle       Vehicle?           @relation("VehicleTrips", fields: [vehicleId], references: [id], onDelete: SetNull)
  route         TransportRoute?    @relation("RouteTrips", fields: [routeId], references: [id], onDelete: SetNull)
  studentEvents StudentTripEvent[] @relation("TripStudentEvents")

  @@index([schoolId, status])
  @@index([driverId, status])
  @@index([vehicleId, status])
  @@index([createdAt])
  @@map("driver_trips")
}

model DriverLocation {
  id         String   @id @default(uuid()) @db.Uuid
  tripId     String?  @map("trip_id") @db.Uuid
  driverId   String   @map("driver_id") @db.Uuid
  vehicleId  String?  @map("vehicle_id") @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  lat        Decimal  @db.Decimal(10, 7)
  lng        Decimal  @db.Decimal(10, 7)
  speed      Float?
  heading    Float?
  accuracy   Float?
  recordedAt DateTime @map("recorded_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at")

  driver  Driver   @relation("DriverLocations", fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation("VehicleLocations", fields: [vehicleId], references: [id], onDelete: SetNull)
  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([driverId, recordedAt])
  @@index([vehicleId, recordedAt])
  @@index([schoolId, recordedAt])
  @@map("driver_locations")
}

model DriverLocationCurrent {
  driverId  String   @id @map("driver_id") @db.Uuid
  vehicleId String?  @unique @map("vehicle_id") @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  lat       Decimal  @db.Decimal(10, 7)
  lng       Decimal  @db.Decimal(10, 7)
  speed     Float?
  heading   Float?
  accuracy  Float?
  tripId    String?  @map("trip_id") @db.Uuid
  updatedAt DateTime @map("updated_at")

  driver  Driver   @relation("DriverLocationCurrent", fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation("VehicleLocationCurrent", fields: [vehicleId], references: [id], onDelete: SetNull)
  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("driver_location_current")
}

// ─── Student Profile Update Requests ────────────────────────────────────────

model StudentProfileUpdateRequest {
  id                  String              @id @default(uuid()) @db.Uuid
  schoolId            String              @map("school_id") @db.Uuid
  studentId           String              @map("student_id") @db.Uuid
  requestedByParentId String              @map("requested_by_parent_id") @db.Uuid
  status              ProfileUpdateStatus @default(PENDING)
  requestedChanges    Json                @map("requested_changes")
  currentValues       Json                @map("current_values")
  reviewNote          String?             @map("review_note") @db.Text
  reviewedByUserId    String?             @map("reviewed_by_user_id") @db.Uuid
  reviewedAt          DateTime?           @map("reviewed_at") @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  school            School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedByParent Parent  @relation("ParentProfileRequests", fields: [requestedByParentId], references: [id], onDelete: Cascade)
  reviewedByUser    User?   @relation("ProfileUpdateReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId, status])
  @@index([studentId])
  @@index([requestedByParentId])
  @@map("student_profile_update_requests")
}

// ─── Student Targeted Notices ────────────────────────────────────────────────

model StudentNotice {
  id            String         @id @default(uuid()) @db.Uuid
  schoolId      String         @map("school_id") @db.Uuid
  studentId     String         @map("student_id") @db.Uuid
  sentByUserId  String         @map("sent_by_user_id") @db.Uuid
  targetStudent Boolean        @default(true) @map("target_student")
  targetParent  Boolean        @default(false) @map("target_parent")
  subject       String         @db.VarChar(255)
  message       String         @db.Text
  priority      NoticePriority @default(NORMAL)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student  Student @relation("StudentTargetedNotices", fields: [studentId], references: [id], onDelete: Cascade)
  sentBy   User    @relation("StudentNoticeSender", fields: [sentByUserId], references: [id], onDelete: Restrict)

  @@index([schoolId])
  @@index([studentId])
  @@index([schoolId, studentId])
  @@map("student_notices")
}

// ─── FCM Tokens (push notifications) ────────────────────────────────────────

model FcmToken {
  id         String   @id @default(uuid()) @db.Uuid
  fcmToken   String   @unique @map("fcm_token") @db.Text
  portalType String   @map("portal_type") @db.VarChar(20)
  parentId   String?  @map("parent_id") @db.Uuid
  studentId  String?  @map("student_id") @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([parentId])
  @@index([studentId])
  @@index([schoolId])
  @@map("fcm_tokens")
}

// ─── Transport: Student Vehicle Assignments ───────────────────────────────────

model StudentVehicleAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  studentId      String    @map("student_id") @db.Uuid
  vehicleId      String    @map("vehicle_id") @db.Uuid
  pickupStopName String?   @map("pickup_stop_name") @db.VarChar(100)
  pickupLat      Decimal?  @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng      Decimal?  @map("pickup_lng") @db.Decimal(10, 7)
  dropStopName   String?   @map("drop_stop_name") @db.VarChar(100)
  dropLat        Decimal?  @map("drop_lat") @db.Decimal(10, 7)
  dropLng        Decimal?  @map("drop_lng") @db.Decimal(10, 7)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  school  School  @relation("SchoolStudentVehicleAssignments", fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation("StudentVehicleAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation("VehicleStudentAssignments", fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([studentId], map: "student_vehicle_assignments_student_unique")
  @@index([schoolId])
  @@index([vehicleId])
  @@index([studentId, isActive])
  @@map("student_vehicle_assignments")
}

// ─── Transport: Student Trip Events ──────────────────────────────────────────

model StudentTripEvent {
  id         String   @id @default(uuid()) @db.Uuid
  tripId     String   @map("trip_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  eventType  String   @map("event_type") @db.VarChar(10)
  lat        Decimal? @db.Decimal(10, 7)
  lng        Decimal? @db.Decimal(10, 7)
  photoUrl   String?  @map("photo_url") @db.Text
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at")

  trip    DriverTrip @relation("TripStudentEvents", fields: [tripId], references: [id], onDelete: Cascade)
  student Student    @relation("StudentTripEvents", fields: [studentId], references: [id], onDelete: Cascade)
  school  School     @relation("SchoolStudentTripEvents", fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([studentId, occurredAt])
  @@index([schoolId])
  @@map("student_trip_events")
}

// ─── Theme Configuration ──────────────────────────────────────────────────────

model ThemeConfig {
  id          String   @id @default(uuid())
  role        String   @db.VarChar(50)
  lightTokens Json     @map("light_tokens")
  darkTokens  Json     @map("dark_tokens")
  presetName  String?  @default("Default") @map("preset_name") @db.VarChar(100)
  updatedBy   String?  @map("updated_by") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([role])
  @@map("theme_configs")
}
